PANEL_BASIC_AUTH_USER=
PANEL_BASIC_AUTH_PASSWORD=
SHEETS_CACHE_SECONDS=60

# Public fallback. Use only during migration.
SHEETS_URLS_JSON={"saldos":"https://docs.google.com/spreadsheets/.../pub?gid=...&single=true&output=csv"}

# Public fallback per sheet. These override SHEETS_URLS_JSON.
SHEET_URL_HISTORICO=
SHEET_URL_FECHAMENTO_SEMANAL=
SHEET_URL_ENTRADAS10D=
SHEET_URL_CONTAS_PAGAR=
SHEET_URL_CONTAS_PAGAR_COMPOSICAO=
SHEET_URL_CONTAS_VENCIDAS=
SHEET_URL_FATURAS_HISTORICO=
SHEET_URL_RUNWAY=
SHEET_URL_SALDOS=
SHEET_URL_TABELA_AUXILIAR=
SHEET_URL_TABELA_RESUMO=
SHEET_URL_ORC_AREAS=
SHEET_URL_DESPESAS_HISTORICO=
SHEET_URL_APORTES_MARIO=
SHEET_URL_ORC_BASE=
SHEET_URL_BASE_DRE=
SHEET_URL_DRE_2026=

# Private Google Sheets API mode. Preferred for production.
# 1. Create a Google Cloud service account.
# 2. Enable Google Sheets API.
# 3. Share each spreadsheet with GOOGLE_SERVICE_ACCOUNT_EMAIL as viewer.
# 4. Configure either SHEETS_PRIVATE_SOURCES_JSON or SHEET_ID_*/SHEET_GID_*.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
SHEETS_PRIVATE_SOURCES_JSON={"saldos":{"spreadsheetId":"...","gid":"306496671"}}

# Multiempresa
# O prefixo vem do id cadastrado em src/empresas/2as-inteligencia-financeira/empresas.js.
# Ex.: direcao-concursos -> DIRECAO_CONCURSOS_*
DIRECAO_CONCURSOS_SHEETS_PRIVATE_SOURCES_JSON={"saldos":{"spreadsheetId":"...","gid":"306496671"}}
DIRECAO_CONCURSOS_SHEET_ID_SALDOS=
DIRECAO_CONCURSOS_SHEET_GID_SALDOS=
DIRECAO_CONCURSOS_SHEET_RANGE_SALDOS=

# Granatum direct labs
# Used only by the experimental endpoint /api/granatum/contas-pagar-labs
GRANATUM_TOKEN=

# Private per sheet. These override SHEETS_PRIVATE_SOURCES_JSON.
SHEET_ID_SALDOS=
SHEET_GID_SALDOS=
SHEET_RANGE_SALDOS=

# Optional enrichment sheet for the operational payables composition.
# Configure after running buscarContasAPagarComposicao() in Apps Script.
SHEET_ID_CONTAS_PAGAR_COMPOSICAO=
SHEET_GID_CONTAS_PAGAR_COMPOSICAO=
SHEET_RANGE_CONTAS_PAGAR_COMPOSICAO=

